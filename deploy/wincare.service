[Unit]
Description=Wincare Node Server
After=network.target mariadb.service
Wants=network.target

[Service]
Type=simple
User=iamkin
WorkingDirectory=/var/www/wincare
Environment=NODE_ENV=production
EnvironmentFile=/var/www/wincare/.env
ExecStart=/usr/bin/node /var/www/wincare/server.js
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
